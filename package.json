{
  "name": "improveo",
  "version": "0.3.0",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev --host --no-qr",
    "dev:local": "pnpm run supabase:start && pnpm run supabase:env:sync && pnpm run dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "setup": "pnpm run supabase:start && pnpm run supabase:env:sync",
    "setup:reset": "pnpm run setup && pnpm run supabase:reset",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "type-check": "nuxt typecheck",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "test:unit": "vitest --project unit",
    "test:nuxt": "vitest --project nuxt",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "format": "prettier --write .",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:status": "supabase status",
    "supabase:reset": "supabase db reset --local",
    "supabase:env:sync": "node scripts/supabase-env-sync.mjs",
    "supabase:gen:types": "supabase gen types typescript --local --schema public > shared/types/database.types.ts"
  },
  "dependencies": {
    "@iconify-json/lucide": "^1.2.89",
    "@internationalized/date": "^3.11.0",
    "@nuxt/eslint": "1.13.0",
    "@nuxt/fonts": "^0.13.0",
    "@nuxt/test-utils": "3.23.0",
    "@nuxt/ui": "^4.4.0",
    "@nuxtjs/supabase": "2.0.3",
    "@pinia/nuxt": "^0.11.3",
    "@vite-pwa/nuxt": "1.1.1",
    "@vueuse/core": "^14.2.0",
    "eslint": "^9.39.2",
    "nuxt": "^4.3.0",
    "pinia": "^3.0.4",
    "tailwindcss": "^4.1.18",
    "vue": "^3.5.27",
    "vue-router": "^4.6.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.1",
    "@vitest/coverage-v8": "^4.0.18",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^20.5.0",
    "playwright-core": "^1.58.1",
    "prettier": "^3.8.1",
    "supabase": "^2.75.5",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "supabase"
    ]
  }
}
